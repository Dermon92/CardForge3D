<Window x:Class="CardForge3D.Preview3DWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3D Preview"
        Width="1200"
        Height="900"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBg}">

    <DockPanel>
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="10">
            <TextBlock Text="Depth"
                       Foreground="{StaticResource TextColor}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <Slider x:Name="DepthSlider"
                    Width="200"
                    Minimum="0"
                    Maximum="24"
                    Value="4"
                    ValueChanged="DepthSlider_ValueChanged"/>
            <Button Content="Refresh" Click="Refresh_Click"/>
        </StackPanel>

        <Grid Background="{StaticResource PanelBgDark}" ClipToBounds="True">
            <Canvas x:Name="PreviewCanvas"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="760"
                    Height="900"
                    ClipToBounds="True"/>
        </Grid>
    </DockPanel>
</Window>