<Window x:Class="CardForge3D.Preview3DWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3D Preview"
        Width="1200"
        Height="900"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBg}">

    <DockPanel>
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="10">
            <TextBlock Text="Depth"
           Foreground="{StaticResource TextColor}"
           VerticalAlignment="Center"
           Margin="0,0,8,0"/>

            <Slider x:Name="DepthSlider"
        Width="220"
        Minimum="0"
        Maximum="24"
        Value="6"
        ValueChanged="DepthSlider_ValueChanged"/>

            <TextBlock x:Name="DepthValueText"
           Text="6"
           Foreground="{StaticResource MutedTextColor}"
           VerticalAlignment="Center"
           Margin="8,0,16,0"/>

            <Button Content="Refresh"
        Click="Refresh_Click"/>

            <TextBlock Text="X"
           Foreground="{StaticResource TextColor}"
           VerticalAlignment="Center"
           Margin="16,0,8,0"/>

            <Slider x:Name="XDirectionSlider"
        Width="120"
        Minimum="-1"
        Maximum="1"
        Value="1"
        TickFrequency="1"
        IsSnapToTickEnabled="True"
        ValueChanged="DirectionSlider_ValueChanged"/>

            <TextBlock Text="Y"
           Foreground="{StaticResource TextColor}"
           VerticalAlignment="Center"
           Margin="16,0,8,0"/>

            <Slider x:Name="YDirectionSlider"
        Width="120"
        Minimum="-1"
        Maximum="1"
        Value="-1"
        TickFrequency="1"
        IsSnapToTickEnabled="True"
        ValueChanged="DirectionSlider_ValueChanged"/>
        </StackPanel>

        <Grid Background="{StaticResource PanelBgDark}" ClipToBounds="True">
            <Canvas x:Name="PreviewCanvas"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="760"
                    Height="900"
                    ClipToBounds="True"/>
        </Grid>
    </DockPanel>
</Window>