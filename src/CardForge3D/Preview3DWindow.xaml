<Window x:Class="CardForge3D.Preview3DWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="http://helix-toolkit.org/wpf"
        Title="Real 3D Preview"
        Width="1200"
        Height="900"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBg}">

    <DockPanel>
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="10">

            <TextBlock Text="Depth Scale"
                       Foreground="{StaticResource TextColor}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <Slider x:Name="DepthScaleSlider"
                    Width="220"
                    Minimum="0"
                    Maximum="0.5"
                    Value="0.08"
                    ValueChanged="DepthScaleSlider_ValueChanged"/>

            <TextBlock x:Name="DepthScaleValueText"
                       Text="0.08"
                       Foreground="{StaticResource MutedTextColor}"
                       VerticalAlignment="Center"
                       Margin="8,0,16,0"/>

            <Button Content="Refresh"
                    Click="Refresh_Click"/>
            <Button Content="Reset View"
        Click="ResetView_Click"/>
        </StackPanel>

        <helix:HelixViewport3D x:Name="Viewport"
                               Background="#1B1B1C"
                               ShowCoordinateSystem="True"
                               ZoomExtentsWhenLoaded="True">
            <helix:SunLight/>
        </helix:HelixViewport3D>
    </DockPanel>
</Window>