<Window x:Class="CardForge3D.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CardForge 3D"
        Height="900"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBg}"
        KeyDown="MainWindow_KeyDown">


    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File"/>
            <MenuItem Header="Edit"/>
            <MenuItem Header="View"/>
            <MenuItem Header="Export"/>
            <MenuItem Header="Help"/>
        </Menu>

        <Border DockPanel.Dock="Top"
                Background="{StaticResource HeaderBg}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="📂 Open" Click="OpenImage_Click"/>
                <Button Content="💾 Save"/>

                <Border Width="1" Height="24" Background="{StaticResource BorderColor}" Margin="8,0"/>

                <Button Content="↶ Undo" Click="Undo_Click"/>
                <Button Content="↷ Redo" Click="Redo_Click"/>

                <Border Width="1" Height="24" Background="{StaticResource BorderColor}" Margin="8,0"/>

                <Button Content="🔍 Zoom"/>
                <Button Content="✋ Pan" Click="PanTool_Click"/>

                <Border Width="1" Height="24" Background="{StaticResource BorderColor}" Margin="8,0"/>

                <Button Content="🖌 Brush" Click="BrushTool_Click"/>

                <Button Content="🧽 Eraser"/>
                
                <Button Content="Magic Wand" Click="MagicWandTool_Click"/>
                <Button Content="3D Preview" Click="Preview3D_Click"/>
            </StackPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="Ready"/>
            <Separator/>
            <StatusBarItem Content="Zoom 100%"/>
            <Separator/>
            <StatusBarItem x:Name="ImageStatus" Content="No image loaded"/>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBg}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,0,1,0">
                <DockPanel Margin="12">
                    <TextBlock DockPanel.Dock="Top"
                               Text="Layers"
                               Foreground="{StaticResource TextColor}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <StackPanel DockPanel.Dock="Bottom"
            Margin="0,12,0,0">

                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ Add" Click="AddLayer_Click"/>
                            <Button Content="- Remove" Click="RemoveLayer_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="↑ Move Up" Click="MoveLayerUp_Click"/>
                            <Button Content="↓ Move Down" Click="MoveLayerDown_Click"/>
                        </StackPanel>

                    </StackPanel>

                    <ListBox x:Name="LayersListBox"
         SelectionChanged="LayersListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True">

                                    <Button Content="{Binding VisibilityIcon}"
                Width="34"
                Margin="0,0,6,0"
                Click="ToggleLayerVisibility_Click"/>

                                    <Button Content="Rename"
                Width="72"
                Margin="0,0,8,0"
                Click="EditLayerName_Click"/>

                                    <Grid>
                                        <TextBlock Text="{Binding Name}"
                       Foreground="{StaticResource TextColor}"
                       VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     Foreground="{StaticResource TextColor}"
                     Background="#333337"
                     BorderBrush="{StaticResource BorderColor}"
                     VerticalAlignment="Center"
                     KeyDown="LayerNameTextBox_KeyDown"
                     LostFocus="LayerNameTextBox_LostFocus">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>

                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource PanelBgDark}"
                    ClipToBounds="True">
                <Grid>
                    <Grid.Background>
                        <DrawingBrush TileMode="Tile"
                                      Viewport="0,0,32,32"
                                      ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="#1E1E1E">
                                    <GeometryDrawing.Geometry>
                                        <GeometryGroup>
                                            <RectangleGeometry Rect="0,0,32,32"/>
                                            <RectangleGeometry Rect="0,0,16,16"/>
                                            <RectangleGeometry Rect="16,16,16,16"/>
                                        </GeometryGroup>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Grid.Background>
                    <Border x:Name="CanvasCardFrame"
        Width="420"
        Height="585"
        BorderBrush="#4A4A50"
        BorderThickness="1"
        Background="#202020"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        MouseWheel="CanvasCardFrame_MouseWheel"
        MouseLeftButtonDown="CanvasCardFrame_MouseLeftButtonDown"
        MouseLeftButtonUp="CanvasCardFrame_MouseLeftButtonUp"
        MouseMove="CanvasCardFrame_MouseMove"
        MouseRightButtonDown="CanvasCardFrame_MouseRightButtonDown"
        MouseRightButtonUp="CanvasCardFrame_MouseRightButtonUp">

                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="CanvasScaleTransform" ScaleX="1" ScaleY="1"/>
                                <TranslateTransform x:Name="CanvasTranslateTransform" X="0" Y="0"/>
                            </TransformGroup>
                        </Border.RenderTransform>

                        <Grid>
                            <TextBlock x:Name="CanvasPlaceholder"
                   Text="Open image to begin"
                   Foreground="{StaticResource MutedTextColor}"
                   FontSize="28"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

                            <ItemsControl x:Name="LayerRenderControl"
              ItemsSource="{Binding ElementName=LayersListBox, Path=ItemsSource}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Grid/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding ImageSource}"
       Stretch="Uniform"
       Opacity="{Binding Opacity}">
                                            <Image.OpacityMask>
                                                <ImageBrush ImageSource="{Binding MaskImageSource}"
                    Stretch="Uniform"/>
                                            </Image.OpacityMask>

                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Canvas IsHitTestVisible="False">
                            <Ellipse x:Name="BrushPreview"
                                 Width="20"
                                 Height="20"
                                 Stroke="White"
                                 StrokeThickness="1"
                                 Fill="Transparent"
                                 IsHitTestVisible="False"
                                 Visibility="Collapsed"/>
                            </Canvas>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBg}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1,0,0,0">
                <StackPanel Margin="12">
                    <TextBlock Text="Properties"
                               Foreground="{StaticResource TextColor}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <TextBlock x:Name="SelectedLayerNameText"
                               Text="No layer selected"
                               Foreground="{StaticResource MutedTextColor}"
                               FontSize="14"/>

                    <Separator Margin="0,16,0,16"/>

                    <TextBlock Text="Brush Size"
                               Foreground="{StaticResource TextColor}"
                               Margin="0,0,0,6"/>
                    <Slider x:Name="BrushSizeSlider"
                                Minimum="1"
                                Maximum="100"
                                Value="20"/>

                    <TextBlock Text="Tolerance"
                               Foreground="{StaticResource TextColor}"
                               Margin="0,16,0,6"/>
                    <Slider x:Name="ToleranceSlider"
                            Minimum="0"
                            Maximum="255"
                            Value="32"
                            ValueChanged="ToleranceSlider_ValueChanged"/>
                    
                    <TextBlock x:Name="ToleranceValueText"
                               Text="32"
                               Foreground="{StaticResource MutedTextColor}"
                               Margin="0,6,0,0"/>
                    <TextBlock Text="Wand Mode"
           Foreground="{StaticResource TextColor}"
           Margin="0,16,0,6"/>

                    <ComboBox x:Name="WandModeComboBox"
          SelectedIndex="0">
                        <ComboBoxItem Content="Contiguous"/>
                        <ComboBoxItem Content="Global"/>
                    </ComboBox>

                    <TextBlock Text="Layer Opacity"
                               Foreground="{StaticResource TextColor}"
                               Margin="0,16,0,6"/>

                    <Slider x:Name="LayerOpacitySlider"
                                Minimum="0"
                                Maximum="100"
                                Value="100"
                                ValueChanged="LayerOpacitySlider_ValueChanged"/>
                    <TextBlock x:Name="LayerOpacityValueText"
                               Text="100%"
                               Foreground="{StaticResource MutedTextColor}"
                               Margin="0,6,0,0"/>
                    <Separator Margin="0,16,0,16"/>
                    <TextBlock Text="Layer Thickness (mm)"
           Foreground="{StaticResource TextColor}"
           Margin="0,16,0,6"/>

                    <Slider x:Name="LayerThicknessSlider"
        Minimum="0"
        Maximum="2"
        Value="0.3"
        TickFrequency="0.1"
        ValueChanged="LayerThicknessSlider_ValueChanged"/>

                    <TextBlock x:Name="LayerThicknessValueText"
           Text="0.3 mm"
           Foreground="{StaticResource MutedTextColor}"
           Margin="0,6,0,0"/>

                    <TextBlock Text="Mask Debug"
                               Foreground="{StaticResource TextColor}"
                               Margin="0,0,0,6"/>

                    <Button Content="Hide Layer Mask"
                            Click="HideLayerMask_Click"/>

                    <Button Content="Show Layer Mask"
                            Click="ShowLayerMask_Click"/>
                </StackPanel>
            </Border>

        </Grid>
    </DockPanel>
</Window>