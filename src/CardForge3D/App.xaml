<Application x:Class="CardForge3D.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">

    <Application.Resources>

        <SolidColorBrush x:Key="WindowBg" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="PanelBg" Color="#252526"/>
        <SolidColorBrush x:Key="PanelBgDark" Color="#1B1B1C"/>
        <SolidColorBrush x:Key="HeaderBg" Color="#2D2D30"/>
        <SolidColorBrush x:Key="BorderColor" Color="#3F3F46"/>
        <SolidColorBrush x:Key="TextColor" Color="#F1F1F1"/>
        <SolidColorBrush x:Key="MutedTextColor" Color="#9A9A9A"/>
        <SolidColorBrush x:Key="ButtonBg" Color="#333337"/>
        <SolidColorBrush x:Key="ButtonHoverBg" Color="#45454A"/>
        <SolidColorBrush x:Key="ButtonPressedBg" Color="#55555C"/>

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource PanelBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>

        <Style TargetType="ToolBarTray">
            <Setter Property="Background" Value="{StaticResource HeaderBg}"/>
        </Style>

        <Style TargetType="ToolBar">
            <Setter Property="Background" Value="{StaticResource HeaderBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="#55555A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource HeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="{StaticResource HeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="{StaticResource HeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        </Style>

    </Application.Resources>
</Application>